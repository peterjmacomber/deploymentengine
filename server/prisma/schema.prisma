// Deployment Engine data model.
// Dev: SQLite (zero-infra). Prod: change provider to "postgresql" and point DATABASE_URL
// at Postgres — the schema is written to port cleanly (no SQLite-only features).
// SQLite has no native JSON/enum types, so complex values are stored as JSON strings
// (columns suffixed *Json) and enums as validated String columns.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  name         String
  role         String // Role enum (admin|manager|agent|readonly|merchant)
  passwordHash String
  active       Boolean   @default(true)
  merchantId   Int? // set only for MERCHANT-role self-service logins
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  merchant Merchant? @relation(fields: [merchantId], references: [id])

  @@index([merchantId])
}

model Merchant {
  id                  Int      @id @default(autoincrement())
  pospMerchantId      Int?
  mid                 String?
  dbaName             String
  legalName           String?
  email               String?
  phone               String?
  primaryContact      String?
  merchantType        String? // POS Portal "type" (e.g. CLIENT)
  taxExempt           Boolean?
  supplyClub          Boolean?
  lastUpdatedAt       DateTime? // POS Portal lastUpdatedDate
  fortisLocationId    String? // linked Fortis Gateway account/location id
  fortisLocationName  String?
  shippingAddressJson String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  orders   Order[]
  deployed DeployedEquipment[]
  users    User[]

  @@index([mid])
}

model Bundle {
  id                    Int      @id @default(autoincrement())
  pospBundleId          Int      @unique
  displayName           String
  description           String?
  active                Boolean  @default(false)
  itemsJson             String   @default("[]")
  application           String?
  encryption            String?
  processorPlatform     String?
  // Real config pulled from POS Portal bundle items (source of truth, matches their site).
  pospApplication       String?
  pospEncryption        String?
  pospOsBuild           String?
  distributor           String   @default("POS Portal")
  accountingDeviceModel String?
  accountingUnitPrice   Float?
  brand                 String?
  pospSnapshotJson      String?
  // Fortis Gateway linkage lives on TerminalModel (per-device catalog), not per-bundle — many
  // bundles share one physical device, and this lets a future bare-terminal order (no bundle)
  // reuse the same linkage. See createFortisTerminalForSerial (orderService.ts).
  terminalModelId       Int?
  terminalModel         TerminalModel? @relation(fields: [terminalModelId], references: [id])
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([active])
  @@index([terminalModelId])
}

// Catalog of physical terminal/device models — one row per device (e.g. "PAX A920 Pro"), shared
// by every Bundle that includes it. Holds Fortis Gateway linkage for BOTH environments (sandbox
// and production are different Fortis accounts with different application/CVM ids for the same
// device — confirmed live 2026-07-20). Also the future anchor for ordering a bare terminal
// (replacement/accessory-only) without a full bundle.
model TerminalModel {
  id                        Int      @id @default(autoincrement())
  name                      String   @unique // matches Bundle.accountingDeviceModel, e.g. "PAX A920 Pro"
  manufacturer              String?  // display brand, e.g. "PAX"
  active                    Boolean  @default(true)
  fortisManufacturerId      String?
  fortisApplicationId       String?
  fortisCvmId               String?
  fortisPaymentPriority     String? // "Credit" | "Debit" -> terminal payment_type_priority
  fortisManufacturerIdProd  String?
  fortisApplicationIdProd   String?
  fortisCvmIdProd           String?
  fortisPaymentPriorityProd String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  bundles Bundle[]
}

// Every manufacturer/application/CVM option discovered live from both Fortis environments (via
// the admin "Add Terminal" forms) — a reference catalog, not per-device config (TerminalModel
// above owns that). Feeds a future admin picker instead of hand-typed ids.
model FortisTerminalOption {
  id               Int      @id @default(autoincrement())
  environment      String // "sandbox" | "production"
  kind             String // "manufacturer" | "application" | "cvm"
  fortisId         String
  label            String
  manufacturerCode String? // for application/cvm rows, which manufacturer they belong to
  lineType         String? // "telium" | "tetra" — Ingenico-specific split; null otherwise
  deprecated       Boolean  @default(false) // true for DNU-*/"DO NOT USE" entries
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([environment, kind, fortisId])
}

model DevicePrice {
  id        Int      @id @default(autoincrement())
  keyword   String   @unique // lowercased match token against a bundle/device name
  model     String // display name, e.g. "Ingenico Link 2500"
  price     Float
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model ForecastEstimate {
  id         Int      @id @default(autoincrement())
  newPartId  String
  month      String // YYYY-MM (the forward month being estimated)
  qty        Int      @default(0)
  updatedBy  String?
  updatedAt  DateTime @updatedAt

  @@unique([newPartId, month])
  @@index([newPartId])
}

model ApiKey {
  id         Int       @id @default(autoincrement())
  name       String
  prefix     String // first chars of the raw key, for identification
  keyHash    String    @unique // sha256 of the full raw key
  active     Boolean   @default(true)
  createdBy  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
}

model Order {
  id                  Int      @id @default(autoincrement())
  pospOrderId         Int?
  reference           String?
  status              String // OrderStatus enum
  method              String // OrderMethod enum
  classification      String // OrderClassification enum
  cancellable         Boolean  @default(true)
  merchantId          Int
  merchantMid         String?
  merchantDba         String?
  shippingAddressJson String?
  linesJson           String   @default("[]")
  shippingMethodLabel String?
  shippingCarrier     String?
  total               Float? // POS Portal totals.grandTotal
  shipDate            DateTime?
  packagesJson        String   @default("[]")
  serialNumbersJson   String   @default("[]")
  originalOrderId     Int?
  createdBy           String?
  originLinkToken     String? // deployment link this order came from
  originLinkName      String?
  syncStatus          String? // synced | local | pending  (sandbox submission state)
  syncError           String?
  shareToken          String?  @unique // public sanitized-tracking link token
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  merchant        Merchant             @relation(fields: [merchantId], references: [id])
  deployed        DeployedEquipment[]
  terminals       FortisTerminalSync[]
  terminalRecords FortisTerminal[]

  @@index([status])
  @@index([merchantId])
  @@index([createdAt])
}

model DeployedEquipment {
  id               Int       @id @default(autoincrement())
  pospId           Int?
  serialNumber     String
  productName      String?
  model            String?
  merchantId       Int
  mid              String?
  orderId          Int?
  status           String    @default("ACTIVE") // DeployedStatus
  deployedAt       DateTime?
  fortisTerminalId String?
  fortisAccountId  String?
  fortisActivated  Boolean   @default(false)
  application      String?
  encryption       String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  merchant Merchant @relation(fields: [merchantId], references: [id])
  order    Order?   @relation(fields: [orderId], references: [id])

  @@index([merchantId])
  @@index([serialNumber])
  @@index([status])
}

model ReturnCase {
  id                 Int      @id @default(autoincrement())
  pospReturnId       Int?     @unique // POS Portal RMA id (for imported returns)
  origin             String?  @default("engine") // engine | posportal
  pospStatus         String? // raw POS Portal RMA status (imported returns), e.g. CLOSED_BY_RETURN
  callTagId          Int?
  entityType         String // order|merchant
  entityId           Int
  merchantId         Int
  mid                String?
  merchantDba        String?
  lifecycle          String // ReturnLifecycle
  callTagStatus      String?
  itemsJson          String   @default("[]")
  expectedItemCount  Int      @default(0)
  receivedItemCount  Int      @default(0)
  delinquent         Boolean  @default(false)
  replacementOrderId Int?
  refundAmount       Float?
  exceptionId        Int?
  daysSinceDeployment Int?
  notes              String?
  createdBy          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([merchantId])
  @@index([lifecycle])
}

model ExceptionRequest {
  id                  Int       @id @default(autoincrement())
  type                String // ExceptionType
  status              String    @default("PENDING") // ExceptionStatus
  requestedBy         String
  requestedAt         DateTime  @default(now())
  reason              String
  merchantId          Int?
  orderId             Int?
  returnCaseId        Int?
  bundlePospId        Int?
  originalPrice       Float?
  requestedPrice      Float?
  serialNumber        String?
  daysSinceDeployment Int?
  decidedBy           String?
  decidedAt           DateTime?
  decisionNote        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([status])
  @@index([type])
}

model FortisTerminalSync {
  id           Int      @id @default(autoincrement())
  orderId      Int
  serialNumber String
  linksValue   String
  terminalId   String?
  accountId    String?
  activated    Boolean  @default(false)
  status       String // created|failed|skipped
  error        String?
  createdAt    DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
}

// A Fortis Gateway terminal this app created for a shipped device. One row per terminal.
// Maps an order+unit to its Fortis terminal id so activation is precise (and, in update-mode,
// so a placeholder can later be updated in place).
model FortisTerminal {
  id           Int      @id @default(autoincrement())
  orderId      Int
  model        String // title model token, e.g. "VP3300"
  title        String // full title, e.g. "VP3300 #1"
  unitIndex    Int      @default(1)
  terminalId   String? // Fortis Gateway terminal id
  locationId   String?
  serialNumber String? // null while a placeholder is pending a real serial (update-mode)
  status       String   @default("placeholder") // placeholder | activated | failed
  error        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([terminalId])
}

model DeploymentLink {
  id                   Int       @id @default(autoincrement())
  token                String    @unique
  type                 String // order | application
  name                 String
  active               Boolean   @default(true)
  merchantId           Int?
  merchantMid          String?
  merchantDba          String?
  bundlePospIdsJson    String    @default("[]")
  pricingOverridesJson String    @default("{}")
  shippingMethodId     Int?
  customFeeName        String?
  customFeeAmount      Float?
  passwordHash         String?
  maxUses              Int?
  usesCount            Int       @default(0)
  expiresAt            DateTime?
  // analytics
  visits               Int       @default(0)
  orders               Int       @default(0)
  unitsVolume          Int       @default(0)
  revenue              Float     @default(0)
  lastUsedAt           DateTime?
  createdBy            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([token])
  @@index([active])
}

model ReportedIssue {
  id                 Int      @id @default(autoincrement())
  merchantId         Int
  merchantDba        String?
  serialNumber       String?
  deviceProduct      String?
  issueCode          String
  issueLabel         String
  notes              String?
  outcome            String // self_resolved | return | swap | pending_review
  returnCaseId       Int?
  replacementOrderId Int?
  createdBy          String? // the merchant login / impersonating actor
  createdAt          DateTime @default(now())

  @@index([merchantId])
  @@index([createdAt])
}

model Setting {
  key       String   @id
  valueJson String
  updatedAt DateTime @updatedAt
}

// Local cache of Fortis Gateway locations (merchants), synced periodically from the live API so
// admin search is a fast local query instead of hitting the gateway on every keystroke.
model FortisLocationCache {
  id            String   @id // Fortis location id
  name          String
  accountNumber String?
  locationType  String?
  updatedAt     DateTime @updatedAt

  @@index([name])
  @@index([accountNumber])
}

model AuditLog {
  id           Int      @id @default(autoincrement())
  actor        String
  actorRole    String
  action       String
  targetType   String?
  targetId     String?
  method       String
  path         String
  ip           String?
  statusCode   Int?
  metadataJson String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([actor])
}
