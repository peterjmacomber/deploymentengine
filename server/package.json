{
  "name": "@de/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --skip-generate",
    "db:reset": "prisma db push --force-reset --accept-data-loss && prisma generate && npm run seed",
    "seed": "tsx prisma/seed.ts",
    "import": "tsx scripts/importRun.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@de/shared": "*",
    "@prisma/client": "^5.19.1",
    "axios": "^1.7.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.7",
    "pino": "^9.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^20.16.5",
    "prisma": "^5.19.1",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
