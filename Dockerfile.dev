# Shared dev image: Node 20 + openssl (required by Prisma). Dependencies are installed at
# runtime into a named volume (see docker-compose.yml) so editing package.json doesn't force
# an image rebuild.
FROM node:20-bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends openssl ca-certificates \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
