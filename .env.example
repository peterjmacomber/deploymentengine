# ---------------------------------------------------------------------------
# Deployment Engine — server environment
# Copy to server/.env for local dev.  Everything runs in MOCK mode by default.
# ---------------------------------------------------------------------------

NODE_ENV=development
PORT=8090
# Comma-separated allowlist of browser origins permitted to call the internal API
CORS_ORIGIN=http://localhost:5175

# --- Auth / security ---
# Long random string. Rotate on any suspected exposure. REQUIRED.
JWT_SECRET=dev-only-change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_TTL=3600            # seconds
BCRYPT_ROUNDS=12

# --- Database (Prisma) ---
# SQLite for dev (resolved relative to server/prisma/). For production set
# provider=postgresql in prisma/schema.prisma and point this at a Postgres URL.
DATABASE_URL="file:./dev.db"

# --- POS Portal integration ---
# mock (default, no creds) | live
# Sandbox -> production is a config-only switch: the code + endpoints are identical, only these
# four values change (prod base URL, prod token URL/scope, and prod client id/secret).
POSP_MODE=mock
POSP_BASE_URL=https://sandbox-wapi.posportal.com/v2   # prod: https://api.posportal.com/v2
POSP_TOKEN_URL=https://login.microsoftonline.com/8b764e43-ba35-498c-ad12-389ce8e0fa29/oauth2/v2.0/token
POSP_SCOPE=https://scansourceb2cqas.onmicrosoft.com/ef0545b0-6b2b-4ea7-b6bd-d8e51bbc6fba/.default
POSP_CLIENT_ID=
POSP_CLIENT_SECRET=

# --- Local-first data: background refresh intervals (seconds) ---
# Connectivity check against POS Portal + Fortis (feeds Admin -> System Status), independent of
# order polling above so it reports even when there's nothing in-flight to poll.
STATUS_POLL_INTERVAL_SECONDS=300
# Consigned-inventory snapshot (Inventory & Forecast page reads this cache, not a live call).
INVENTORY_POLL_INTERVAL_SECONDS=900
# Full paginated re-sync of Fortis Gateway locations into the local search cache (8,500+ rows —
# infrequent by design; also triggerable on demand from the Fortis Gateway page).
FORTIS_LOCATION_SYNC_INTERVAL_SECONDS=21600

# --- Fortis Gateway (Zeamster) — always the live API (no mock) ---
# Two DIFFERENT API hosts, confirmed live 2026-07-16 (not interchangeable):
#   FORTIS_BASE_URL          -> /v1 locations (merchant search) + terminal-defaults dropdowns
#   FORTIS_TERMINALS_BASE_URL -> /v2 terminals (create/list/update, provisioning)
FORTIS_BASE_URL=https://api.sandbox.fortis.tech          # prod: https://api.fortis.tech
FORTIS_TERMINALS_BASE_URL=https://api.sandbox.zeamster.com
FORTIS_MERCHANT_LOGIN_URL=https://<tenant>.sandbox.zeamster.com
FORTIS_DEVELOPER_ID=
FORTIS_USER_ID=
FORTIS_USER_NAME=
FORTIS_USER_API_KEY=
FORTIS_USER_HASH_KEY=
FORTIS_TICKET_HASH_KEY=
# sandbox (default) | production — selects which per-bundle Fortis terminal ids
# (fortisManufacturerId/fortisApplicationId/fortisCvmId vs the *Prod columns) get used. Flip
# together with pointing FORTIS_BASE_URL/FORTIS_TERMINALS_BASE_URL/credentials at production.
FORTIS_ENV=sandbox
FORTIS_LOCATION_ID=
# Pre-created sandbox location every public Apply-flow signup links to (Fortis has no
# self-service "create merchant account" API — POST /v1/onboarding is a full boarding
# application). Has no account_number by design.
FORTIS_APPLY_LOCATION_ID=
FORTIS_TERMINAL_ID=
# Terminal defaults are normally set on the admin Fortis Gateway page (persisted in the DB).
# These only SEED the initial values. terminal_manufacturer_code is a string: 2=Ingenico, 1=PAX, 4=IDtech, 100=Virtual Device.
FORTIS_TERMINAL_APPLICATION_ID=
FORTIS_TERMINAL_CVM_ID=
FORTIS_TERMINAL_MANUFACTURER_CODE=2
FORTIS_LINK_FIELD=terminal_api_id

# --- Webhooks (POS Portal -> us) ---
# Scheme is AM-negotiated. Supported: apikey | hmac | bearer  (default apikey for dev)
WEBHOOK_AUTH_SCHEME=apikey
WEBHOOK_API_KEY=dev-webhook-key-change-me
WEBHOOK_HMAC_SECRET=

# --- Public / embed API ---
# API keys that external partners (e.g. the e-sign application) use for the embed flow.
# Comma-separated key:label pairs. Rotate regularly.
PUBLIC_API_KEYS=demo-partner-key:E-Sign Application (Demo)
PUBLIC_ALLOWED_RETURN_HOSTS=localhost,esign.example.com
